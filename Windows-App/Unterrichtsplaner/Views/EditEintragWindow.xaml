<Window x:Class="Unterrichtsplaner.Views.EditEintragWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eintrag bearbeiten" Height="400" Width="430"
        Background="#1d1d1f" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock x:Name="FachText" FontSize="18" FontWeight="Bold" Foreground="#6e56cf"/>
            <TextBlock Text="  " FontSize="18"/>
            <TextBlock x:Name="KlasseText" FontSize="18" FontWeight="SemiBold" Foreground="#f5f5f7"/>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="Thema" Foreground="#86868b" FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
            <TextBox x:Name="ThemaBox" Background="#2d2d2f" Foreground="#f5f5f7" BorderBrush="#3a3a3c" BorderThickness="1" CaretBrush="White" SelectionBrush="#6e56cf" FontSize="14" Padding="10,8"/>
        </StackPanel>
        <StackPanel Grid.Row="4">
            <TextBlock Text="Notiz" Foreground="#86868b" FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
            <TextBox x:Name="NotizBox" Background="#2d2d2f" Foreground="#f5f5f7" BorderBrush="#3a3a3c" BorderThickness="1" CaretBrush="White" SelectionBrush="#6e56cf" FontSize="13" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True" Height="72" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
        <StackPanel Grid.Row="6">
            <TextBlock Text="Status" Foreground="#86868b" FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
            <ComboBox x:Name="StatusBox" Background="#2d2d2f" Foreground="#f5f5f7" BorderBrush="#3a3a3c" BorderThickness="1" FontSize="13" Padding="8,6"/>
        </StackPanel>
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Click="CancelClicked" Background="#2d2d2f" Foreground="#86868b" BorderBrush="#3a3a3c" BorderThickness="1" Padding="16,8" FontSize="13" Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Speichern" Click="SaveClicked" Background="#6e56cf" Foreground="White" BorderThickness="0" Padding="16,8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
